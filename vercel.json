{
    "version": 2,
    "builds": [
        { "src": "./index.js", "use": "@vercel/node" }
    ],
    "routes": [
        { "src": "/api/(.*)", "dest": "/" },
        {
            "src": "/(.*)",
            "status": 302,
            "headers": { "Location": "https://satwebtdi.netlify.app/$1" }
        }
    ],
    "crons": [
        { "path": "/api/v2/internal/archive-overdue-tick", "schedule": "0 6 * * *" }
    ]
}
